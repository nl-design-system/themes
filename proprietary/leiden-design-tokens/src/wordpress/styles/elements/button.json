{
  "button": {
    "border": {
      "radius": "{basis.border-radius.md}",
      "color": "{basis.color.default.border-default}",
      "style": "solid",
      "width": "{basis.border-width.md}"
    },
    "color": {
      "text": "{basis.color.default.color-default}",
      "background": "{basis.color.transparent}"
    },
    "dimensions": {},
    "filter": {},
    "shadow": {},
    "spacing": {
      "padding": {
        "top": "{basis.space.block.lg}",
        "right": "{basis.space.inline.xl}",
        "bottom": "{basis.space.block.lg}",
        "left": "{basis.space.inline.xl}"
      }
    },
    "typography": {
      "fontFamily": "{basis.text.font-family.default}",
      "fontWeight": "{basis.text.font-weight.bold}",
      "fontSize": "{basis.text.font-size.md}",
      "lineHeight": "{basis.text.line-height.md}"
    },
    ":hover": {
      "color": {
        "text": "{basis.color.default.color-hover}",
        "background": "{basis.color.default.bg-hover}"
      },
      "border": {
        "color": "{basis.color.default.border-hover}"
      }
    },
    ":active": {
      "color": {
        "text": "{basis.color.default.color-active}",
        "background": "{basis.color.default.bg-active}"
      },
      "border": {
        "color": "{basis.color.default.border-active}"
      }
    },
    ":focus": {
      "color": {
        "text": "{basis.focus.color}",
        "background": "{basis.focus.background-color}"
      },
      "border": {
        "color": "{basis.color.transparent}"
      }
    }
  }
}
