{
  "core/button": {
    "variations": {
      "fill": {
        "border": {
          "radius": "{basis.border-radius.md}",
          "color": "{basis.color.transparent}",
          "style": "solid",
          "width": "{basis.border-width.md}"
        },
        "color": {
          "text": "{basis.color.action-1-inverse.color-default}",
          "background": "{basis.color.action-1-inverse.bg-default}"
        },
        "dimensions": {},
        "filter": {},
        "shadow": {},
        "spacing": {
          "padding": {
            "top": "{basis.space.block.lg}",
            "right": "{basis.space.inline.lg}",
            "bottom": "{basis.space.block.lg}",
            "left": "{basis.space.inline.lg}"
          }
        },
        "typography": {
          "fontWeight": "{basis.text.font-weight.bold}",
          "fontSize": "{basis.text.font-size.md}",
          "lineHeight": "{basis.text.line-height.md}"
        },
        ":hover": {
          "color": {
            "text": "{basis.color.action-1-inverse.color-hover}",
            "background": "{basis.color.action-1-inverse.bg-hover}"
          },
          "border": {
            "color": "{basis.color.transparent}"
          }
        },
        ":active": {
          "color": {
            "text": "{basis.color.action-1-inverse.color-active}",
            "background": "{basis.color.action-1-inverse.bg-active}"
          },
          "border": {
            "color": "{basis.color.transparent}"
          }
        },
        ":focus": {
          "color": {
            "text": "{basis.focus.color}",
            "background": "{basis.focus.background-color}"
          },
          "border": {
            "color": "{basis.color.transparent}"
          }
        }
      },
      "outline": {
        "border": {
          "radius": "{basis.border-radius.md}",
          "color": "{basis.color.action-2.border-default}",
          "style": "solid",
          "width": "{basis.border-width.md}"
        },
        "color": {
          "text": "{basis.color.action-2.color-default}",
          "background": "{basis.color.transparent}"
        },
        "dimensions": {},
        "filter": {},
        "shadow": {},
        "spacing": {
          "padding": {
            "top": "{basis.space.block.lg}",
            "right": "{basis.space.inline.lg}",
            "bottom": "{basis.space.block.lg}",
            "left": "{basis.space.inline.lg}"
          }
        },
        "typography": {
          "fontWeight": "{basis.text.font-weight.bold}",
          "fontSize": "{basis.text.font-size.md}",
          "lineHeight": "{basis.text.line-height.md}"
        },
        ":hover": {
          "color": {
            "text": "{basis.color.action-2.color-hover}",
            "background": "{basis.color.action-2.bg-hover}"
          },
          "border": {
            "color": "{basis.color.action-2.border-hover}"
          }
        },
        ":active": {
          "color": {
            "text": "{basis.color.action-2.color-active}",
            "background": "{basis.color.action-2.bg-active}"
          },
          "border": {
            "color": "{basis.color.action-2.border-active}"
          }
        },
        ":focus": {
          "color": {
            "text": "{basis.focus.color}",
            "background": "{basis.focus.background-color}"
          },
          "border": {
            "color": "{basis.color.transparent}"
          }
        },
        "css": "&:hover { background-color: {basis.color.action-2.bg-hover}; color: {basis.color.action-2.color-hover}; border-color: {basis.color.action-2.border-hover}; } &:active { background-color: {basis.color.action-2.bg-active}; color: {basis.color.action-2.color-active}; border-color: {basis.color.action-2.border-active}; } &:focus { background-color: {basis.focus.background-color}; color: {basis.focus.color}; border-color: {basis.color.transparent}; }"
      }
    }
  }
}
